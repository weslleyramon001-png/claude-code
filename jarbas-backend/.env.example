# ============================================================
# JARBAS — Arquivo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores abaixo.
# NUNCA commite o arquivo .env no GitHub!
# ============================================================


# ── OBRIGATÓRIO: Anthropic / Claude ─────────────────────────
# Obtenha em: https://console.anthropic.com/
# Crie uma conta, vá em "API Keys" e gere uma nova chave.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OPCIONAL: ElevenLabs (Síntese de Voz) ───────────────────
# Obtenha em: https://elevenlabs.io/ (plano gratuito disponível)
# Após criar conta, vá em "Profile" > "API Key"
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID da voz a ser usada.
# Vozes em PT-BR recomendadas (copie o ID desejado):
#   Mateus  (masculino, claro):    XrExE9yKIg1WjnnlVkGX
#   Daniel  (masculino, profundo): onwK4e9ZLuTAKqWW03F9
#   Adam    (inglês, padrão):      pNInz6obpgDQGcFmaJgB
# Para ver todas as vozes: https://elevenlabs.io/voice-library
# Ou use a API: GET https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX


# ── OPCIONAL: Tavily (Busca na Web) ─────────────────────────
# Obtenha em: https://tavily.com/ (1000 buscas grátis/mês)
# Após criar conta, copie sua API key do dashboard.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Segurança ────────────────────────────────────────────────
# Chave secreta para sessões. Mude para um valor aleatório longo em produção.
# Gere um com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-para-algo-aleatorio-e-longo-em-producao


# ── CORS ─────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula. Use * para desenvolvimento.
# Em produção, especifique o domínio do seu frontend:
# Exemplo: https://meusite.com,https://jarbas.up.railway.app
ALLOWED_ORIGINS=*


# ── Banco de dados ───────────────────────────────────────────
# Caminho do arquivo SQLite para memória do JARBAS.
# Em Railway/containers, use /data/jarbas_memory.db (volume persistente)
DB_PATH=jarbas_memory.db


# ── Servidor ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Máximo de tokens por resposta (2048 é um bom equilíbrio)
MAX_TOKENS=2048

# Quantas mensagens anteriores incluir no contexto (memória de curto prazo)
HISTORY_LIMIT=20
